      \u003cli\u003e\u003ca href=\"#client-certs\"\u003eClient Certs\u003c/a\u003e\u003c/li\u003e\n      \u003c/ul\u003e\n    \u003c/div\u003e\n  \u003c/nav\u003e\n\n  \u003cmain class=\"container\"\u003e\n    \u003cheader class=\"hero\"\u003e\n      \u003chgroup\u003e\n        \u003ch1\u003eSulibot PKI\u003c/h1\u003e\n        \u003cp\u003eSmallstep CA endpoint for homelab certificate issuance, client identity certificates, and ACME automation.\u003c/p\u003e\n      \u003c/hgroup\u003e\n      \u003cp\u003eUse the fields below to copy the CA URL, verify the root fingerprint, and run the commands you actually need without reading through vendor docs first.\u003c/p\u003e\n      \u003cdiv class=\"hero-actions\"\u003e\n        \u003ca href=\"/roots.pem\" role=\"button\" class=\"secondary\"\u003eDownload Roots\u003c/a\u003e\n        \u003ca href=\"/acme/acme/directory\" role=\"button\" class=\"secondary\"\u003eOpen ACME Directory\u003c/a\u003e\n        \u003ca href=\"/health\" role=\"button\" class=\"secondary\"\u003eCheck Health\u003c/a\u003e\n      \u003c/div\u003e\n    \u003c/header\u003e\n\n    \u003cdiv class=\"grid stats\"\u003e\n      \u003cdiv class=\"stat\"\u003e\n        \u003clabel\u003eCA URL\u003c/label\u003e\n        \u003cstrong\u003ehttps://pki.sulibot.com\u003c/strong\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"stat\"\u003e\n        \u003clabel\u003eRoot Fingerprint\u003c/label\u003e\n        \u003cstrong\u003e$FINGERPRINT\u003c/strong\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"stat\"\u003e\n        \u003clabel\u003eDefault Provisioner\u003c/label\u003e\n        \u003cstrong\u003eadmin@sulibot.com\u003c/strong\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"stat\"\u003e\n        \u003clabel\u003eACME Provisioner\u003c/label\u003e\n        \u003cstrong\u003eacme\u003c/strong\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003carticle id=\"quickstart\"\u003e\n      \u003cheader\u003e\n        \u003chgroup\u003e\n          \u003ch2\u003eQuick Start\u003c/h2\u003e\n          \u003cp\u003eThe top two values most clients need, followed by the first bootstrap command.\u003c/p\u003e\n        \u003c/hgroup\u003e\n      \u003c/header\u003e\n      \u003cdiv class=\"callout success\"\u003e\n        \u003cp\u003e\u003cstrong\u003eExpected behavior:\u003c/strong\u003e this page is the operator landing page. API endpoints like \u003ccode\u003e/roots.pem\u003c/code\u003e, \u003ccode\u003e/health\u003c/code\u003e, and the ACME directory stay live behind the same hostname.\u003c/p\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"field\"\u003e\n        \u003clabel for=\"ca-url\"\u003eCA URL\u003c/label\u003e\n        \u003cinput id=\"ca-url\" value=\"https://pki.sulibot.com\" readonly\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"field\"\u003e\n        \u003clabel for=\"root-fingerprint\"\u003eRoot Fingerprint\u003c/label\u003e\n        \u003cinput id=\"root-fingerprint\" value=\"$FINGERPRINT\" readonly\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"command-grid\"\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eBootstrap a workstation\u003c/h3\u003e\n              \u003cp\u003eRun once on any machine that will use the \u003ccode\u003estep\u003c/code\u003e CLI against this CA.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca bootstrap \\\n  --ca-url https://pki.sulibot.com \\\n  --fingerprint $FINGERPRINT\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eSet ACME directory\u003c/h3\u003e\n              \u003cp\u003eUseful for Caddy, Traefik, cert-manager testing, or shell-based clients.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003eACME_DIRECTORY=https://pki.sulibot.com/acme/acme/directory\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n      \u003c/div\u003e\n    \u003c/article\u003e\n\n    \u003carticle\u003e\n      \u003cheader\u003e\n        \u003chgroup\u003e\n          \u003ch2\u003eService Endpoints\u003c/h2\u003e\n          \u003cp\u003eDirect links for the live CA resources exposed on this host.\u003c/p\u003e\n        \u003c/hgroup\u003e\n      \u003c/header\u003e\n      \u003cdiv class=\"endpoint-list\"\u003e\n        \u003cdiv class=\"endpoint\"\u003e\n          \u003cstrong\u003eRoots Bundle\u003c/strong\u003e\n          \u003ca href=\"/roots.pem\"\u003ehttps://pki.sulibot.com/roots.pem\u003c/a\u003e\n        \u003c/div\u003e\n        \u003cdiv class=\"endpoint\"\u003e\n          \u003cstrong\u003eHealth Check\u003c/strong\u003e\n          \u003ca href=\"/health\"\u003ehttps://pki.sulibot.com/health\u003c/a\u003e\n        \u003c/div\u003e\n        \u003cdiv class=\"endpoint\"\u003e\n          \u003cstrong\u003eACME Directory\u003c/strong\u003e\n          \u003ca href=\"/acme/acme/directory\"\u003ehttps://pki.sulibot.com/acme/acme/directory\u003c/a\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/article\u003e\n\n    \u003carticle id=\"operations\"\u003e\n      \u003cheader\u003e\n        \u003chgroup\u003e\n          \u003ch2\u003eCommon Operations\u003c/h2\u003e\n          \u003cp\u003eRoutine commands for validation, inspection, and day-to-day CA checks.\u003c/p\u003e\n        \u003c/hgroup\u003e\n      \u003c/header\u003e\n      \u003cdiv class=\"command-grid\"\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eInspect the CA\u003c/h3\u003e\n              \u003cp\u003eVerify trust material, service health, and the ACME endpoint.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep certificate fingerprint https://pki.sulibot.com/roots.pem\nstep ca provisioner list\nhttp https://pki.sulibot.com/health\nhttp https://pki.sulibot.com/acme/acme/directory\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eIssue a smoke-test certificate\u003c/h3\u003e\n              \u003cp\u003eQuick validation that signing is working end to end.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca certificate smoke-test \\\n  smoke-test.crt \\\n  smoke-test.key \\\n  --provisioner admin@sulibot.com\n\nstep certificate inspect smoke-test.crt --short\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003ePrint the root fingerprint\u003c/h3\u003e\n              \u003cp\u003eUseful when bootstrapping a new client or validating copied trust data.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep certificate fingerprint https://pki.sulibot.com/roots.pem\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eList provisioners\u003c/h3\u003e\n              \u003cp\u003eShows the current JWK, ACME, and any later OIDC provisioners.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca provisioner list\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n      \u003c/div\u003e\n    \u003c/article\u003e\n\n    \u003carticle id=\"oidc\"\u003e\n      \u003cheader\u003e\n        \u003chgroup\u003e\n          \u003ch2\u003eOIDC Provisioner\u003c/h2\u003e\n          \u003cp\u003eTemplate for adding an Authentik-backed OIDC provisioner. Replace placeholders before running it.\u003c/p\u003e\n        \u003c/hgroup\u003e\n      \u003c/header\u003e\n      \u003cdiv class=\"callout warning\"\u003e\n        \u003cp\u003e\u003cstrong\u003eBefore you run this:\u003c/strong\u003e create the OIDC client in Authentik, confirm the discovery URL, and decide which email domains or groups should be trusted for certificate issuance.\u003c/p\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"command-grid\"\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eAdd provisioner\u003c/h3\u003e\n              \u003cp\u003eCreates a new OIDC provisioner that delegates login to Authentik.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca provisioner add authentik \\\n  --type OIDC \\\n  --client-id YOUR_CLIENT_ID \\\n  --client-secret YOUR_CLIENT_SECRET \\\n  --configuration-endpoint https://auth.sulibot.com/application/o/YOUR_APP/.well-known/openid-configuration \\\n  --domain sulibot.com \\\n  --admin admin@sulibot.com\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eVerify the new provisioner\u003c/h3\u003e\n              \u003cp\u003eRun after adding it to confirm it appears in the local CA configuration.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca provisioner list | grep authentik\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n      \u003c/div\u003e\n    \u003c/article\u003e\n\n    \u003carticle id=\"client-certs\"\u003e\n      \u003cheader\u003e\n        \u003chgroup\u003e\n          \u003ch2\u003eClient Certificate Workflow\u003c/h2\u003e\n          \u003cp\u003eUse this sequence when a browser, laptop, script, or local service needs a client identity certificate for mutual TLS.\u003c/p\u003e\n        \u003c/hgroup\u003e\n      \u003c/header\u003e\n      \u003cdiv class=\"command-grid\"\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eIssue a client certificate\u003c/h3\u003e\n              \u003cp\u003eCreates a certificate and private key for a user or device identity.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca certificate alice-laptop \\\n  alice-laptop.crt \\\n  alice-laptop.key \\\n  --provisioner admin@sulibot.com\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eInspect the certificate\u003c/h3\u003e\n              \u003cp\u003eConfirm subject, issuer, and validity dates before distribution.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep certificate inspect alice-laptop.crt --short\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eCreate a PKCS#12 bundle\u003c/h3\u003e\n              \u003cp\u003eBundle the certificate and key for browser or OS import.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep certificate p12 \\\n  alice-laptop.p12 \\\n  alice-laptop.crt \\\n  alice-laptop.key\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eUse it with curl\u003c/h3\u003e\n              \u003cp\u003eSimple test against an mTLS-protected endpoint.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003ecurl \\\n  --cert alice-laptop.crt \\\n  --key alice-laptop.key \\\n  https://YOUR_MTLS_SERVICE\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eUse it with HTTPie\u003c/h3\u003e\n              \u003cp\u003eEquivalent workflow for HTTPie-based API testing.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003ehttp \\\n  --cert alice-laptop.crt \\\n  --cert-key alice-laptop.key \\\n  https://YOUR_MTLS_SERVICE\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n        \u003csection class=\"command-card\"\u003e\n          \u003cdiv class=\"command-head\"\u003e\n            \u003cdiv\u003e\n              \u003ch3\u003eRenew an existing certificate\u003c/h3\u003e\n              \u003cp\u003eReuse the existing keypair and update the certificate in place.\u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cpre\u003e\u003ccode\u003estep ca renew \\\n  alice-laptop.crt \\\n  alice-laptop.key\u003c/code\u003e\u003c/pre\u003e\n        \u003c/section\u003e\n      \u003c/div\u003e\n    \u003c/article\u003e\n  \u003c/main\u003e\n\n  \u003cfooter\u003e\n    \u003cdiv class=\"container\"\u003e\n      \u003csmall\u003eSulibot PKI. Backed by Smallstep \u003ccode\u003estep-ca\u003c/code\u003e and Caddy. This page is an operator landing page, not a full admin UI.\u003c/small\u003e\n    \u003c/div\u003e\n  \u003c/footer\u003e\n\u003c/body\u003e\n\u003c/html\u003e\nHTML", "cat \u003e /etc/caddy/Caddyfile \u003c\u003c'CFG'\n{\n  admin off\n}\n\npki.sulibot.com {\n  tls /etc/caddy/certs/pki.sulibot.com.crt /etc/caddy/certs/pki.sulibot.com.key\n\n  handle / {\n    root * /var/www/pki\n    file_server\n  }\n\n  handle {\n    reverse_proxy https://127.0.0.1:9000 {\n      transport http {\n        tls_insecure_skip_verify\n      }\n    }\n  }\n}\nCFG", "systemctl daemon-reload", "systemctl enable --now caddy", "systemctl restart caddy", "curl --resolve pki.sulibot.com:443:127.0.0.1 -ksS -o /dev/null https://pki.sulibot.com/"]
  }
}

resource "routeros_ip_dns_record" "smallstep_host_ipv4" {
  name    = local.host_domain
  type    = "A"
  address = "10.100.0.64"
  ttl     = "5m"
  comment = "managed by terraform smallstep-lxc"
}

resource "routeros_ip_dns_record" "smallstep_host_ipv6" {
  name    = local.host_domain
  type    = "AAAA"
  address = "fd00:100::64"
  ttl     = "5m"
  comment = "managed by terraform smallstep-lxc"
}

resource "routeros_ip_dns_record" "smallstep_service_cname" {
  name    = local.service_domain
  type    = "CNAME"
  cname   = local.host_domain
  ttl     = "5m"
  comment = "managed by terraform smallstep-lxc"
}

resource "null_resource" "smallstep_1password_sync" {
  depends_on = [module.smallstep_lxc, null_resource.smallstep_caddy_frontend]

  triggers = {
    service_domain = local.service_domain
    sync_rev       = "smallstep-1password-v1"
  }

  provisioner "local-exec" {
    command = <<-OPCMD
      set -euo pipefail
      SSH_OPTS="-i $HOME/.ssh/id_ed25519 -o BatchMode=yes -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

      timeout 10 op whoami >/dev/null 2>&1 || { echo "Skipping 1Password PKI sync: 1Password CLI is not authenticated"; exit 0; }

      ITEM_ID="$(timeout 15 op item get "smallstep-pki" --vault "Kubernetes" --format json 2>/dev/null | jq -r '.id' || true)"
      if [ -z "$ITEM_ID" ] || [ "$ITEM_ID" = "null" ]; then
        ITEM_ID="$(timeout 15 op item create \
          --vault="Kubernetes" \
          --title="smallstep-pki" \
          --category=server \
          "hostname[text]=pki.sulibot.com" \
          "host_node[text]=pki01.sulibot.com" \
          "ca_url[text]=https://pki.sulibot.com" \
          --format json | jq -r '.id')"
      fi

      ROOT_CRT="$(timeout 20 ssh $SSH_OPTS root@10.100.0.64 'cat /etc/step-ca/certs/root_ca.crt')"
      INTERMEDIATE_CRT="$(timeout 20 ssh $SSH_OPTS root@10.100.0.64 'cat /etc/step-ca/certs/intermediate_ca.crt')"
      INTERMEDIATE_KEY_B64="$(timeout 20 ssh $SSH_OPTS root@10.100.0.64 'base64 -w0 /etc/step-ca/secrets/intermediate_ca_key')"
      FINGERPRINT="$(timeout 20 ssh $SSH_OPTS root@10.100.0.64 'step certificate fingerprint /etc/step-ca/certs/root_ca.crt')"
      CA_JSON_B64="$(timeout 20 ssh $SSH_OPTS root@10.100.0.64 'base64 -w0 /etc/step-ca/config/ca.json')"

      timeout 20 op item edit "$ITEM_ID" \
        --vault="Kubernetes" \
        "hostname[text]=pki.sulibot.com" \
        "host_node[text]=pki01.sulibot.com" \
        "ca_url[text]=https://pki.sulibot.com" \
        "ca_password[password]=${var.smallstep_ca_password}" \
        "provisioner_password[password]=${var.smallstep_provisioner_password}" \
        "root_ca_crt[text]=$ROOT_CRT" \
        "intermediate_ca_crt[text]=$INTERMEDIATE_CRT" \
        "root_ca_fingerprint[text]=$FINGERPRINT" \
        "intermediate_ca_key_base64[concealed]=$INTERMEDIATE_KEY_B64" \
        "ca_json_base64[concealed]=$CA_JSON_B64"
    OPCMD
  }
}
