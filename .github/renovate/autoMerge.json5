{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Do not auto-merge major updates",
      matchUpdateTypes: ["major"],
      automerge: false,
    },
    {
      description: "Auto-merge trusted container digests",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["digest"],
      matchPackageNames: ["/home-operations/"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge OCI Charts",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["/kube-prometheus-stack/"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge trusted GitHub Actions",
      matchManagers: ["github-actions"],
      matchPackageNames: [
        "/^actions\//",
        "/^renovatebot\//",
      ],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "1 minute",
      ignoreTests: true,
    },
    {
      description: "Auto-merge patch container updates",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["patch"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge minor container updates for low-risk applications",
      matchDatasources: ["docker"],
      matchFileNames: [
        "kubernetes/apps/tier-1-infrastructure/gatus/**",
        "kubernetes/apps/tier-2-applications/actual/**",
        "kubernetes/apps/tier-2-applications/atuin/**",
        "kubernetes/apps/tier-2-applications/audiobookshelf/**",
        "kubernetes/apps/tier-2-applications/autobrr/**",
        "kubernetes/apps/tier-2-applications/bookshelf/**",
        "kubernetes/apps/tier-2-applications/calibre-web-automated/**",
        "kubernetes/apps/tier-2-applications/cloudbeaver/**",
        "kubernetes/apps/tier-2-applications/cross-seed/**",
        "kubernetes/apps/tier-2-applications/digarr/**",
        "kubernetes/apps/tier-2-applications/emby/**",
        "kubernetes/apps/tier-2-applications/flaresolverr/**",
        "kubernetes/apps/tier-2-applications/freshrss/**",
        "kubernetes/apps/tier-2-applications/homepage/**",
        "kubernetes/apps/tier-2-applications/jellyseerr/**",
        "kubernetes/apps/tier-2-applications/karakeep/**",
        "kubernetes/apps/tier-2-applications/lazylibrarian/**",
        "kubernetes/apps/tier-2-applications/lidarr/**",
        "kubernetes/apps/tier-2-applications/mediasage/**",
        "kubernetes/apps/tier-2-applications/miniflux/**",
        "kubernetes/apps/tier-2-applications/multi-scrobbler/**",
        "kubernetes/apps/tier-2-applications/navidrome/**",
        "kubernetes/apps/tier-2-applications/notifiarr/**",
        "kubernetes/apps/tier-2-applications/nzbget/**",
        "kubernetes/apps/tier-2-applications/overseerr/**",
        "kubernetes/apps/tier-2-applications/paperless-gpt/**",
        "kubernetes/apps/tier-2-applications/prowlarr/**",
        "kubernetes/apps/tier-2-applications/qui/**",
        "kubernetes/apps/tier-2-applications/radarr/**",
        "kubernetes/apps/tier-2-applications/radarr-4k/**",
        "kubernetes/apps/tier-2-applications/recyclarr/**",
        "kubernetes/apps/tier-2-applications/sabnzbd/**",
        "kubernetes/apps/tier-2-applications/seerr/**",
        "kubernetes/apps/tier-2-applications/shelfmark/**",
        "kubernetes/apps/tier-2-applications/slskd/**",
        "kubernetes/apps/tier-2-applications/sonarr/**",
        "kubernetes/apps/tier-2-applications/sonarr-4k/**",
        "kubernetes/apps/tier-2-applications/sportarr/**",
        "kubernetes/apps/tier-2-applications/stirling-pdf/**",
        "kubernetes/apps/tier-2-applications/tautulli/**",
        "kubernetes/apps/tier-2-applications/tqm/**",
        "kubernetes/apps/tier-2-applications/tuppr/**",
      ],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge GitHub Releases",
      matchDatasources: ["github-releases"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["/external-dns/", "/gateway-api/", "/prometheus-operator/"],
      ignoreTests: true,
    },
    {
      description: "Auto-merge Terraform/OpenTofu providers and modules",
      matchManagers: ["terraform"],
      matchDatasources: ["terraform-provider", "terraform-module"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge Terragrunt non-major updates",
      matchManagers: ["terragrunt"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge Ansible Galaxy non-major updates",
      matchManagers: ["ansible-galaxy"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
  ],
}
