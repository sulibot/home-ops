{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>sulibot/home-ops//.github/renovate/autoMerge.json5",
    "github>sulibot/home-ops//.github/renovate/changelogs.json5",
    "github>sulibot/home-ops//.github/renovate/customManagers.json5",
    "github>sulibot/home-ops//.github/renovate/grafanaDashboards.json5",
    "github>sulibot/home-ops//.github/renovate/groups.json5",
    "github>sulibot/home-ops//.github/renovate/labels.json5",
    "github>sulibot/home-ops//.github/renovate/overrides.json5",
    "github>sulibot/home-ops//.github/renovate/semanticCommits.json5",
    ":automergeBranch",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/Los_Angeles)",
  ],
  prHourlyLimit: 4,
  prConcurrentLimit: 15,
  schedule: [
    "after 10pm and before 5am every weekday",
    "every weekend",
  ],
  updateNotScheduled: false,
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 4am on monday"],
    automerge: true,
  },
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: [
    "prEditedNotification",
    "prIgnoreNotification",
  ],
  ignorePaths: [
    "**/*.sops.*",
    "**/resources/**",
    "**/.terragrunt-cache/**",
    "**/*.backup",
    "**/*.before-reorg",
    "archieve/**",
    "ansible/lae.proxmox/collections/**",
  ],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  terragrunt: {
    managerFilePatterns: [
      "/(^|/)terragrunt\\.hcl$/",
    ],
  },
  terraform: {
    managerFilePatterns: [
      "/(^|/).*\\.tf$/",
      "/(^|/)versions\\.tf$/",
    ],
  },
  ansible: {
    managerFilePatterns: [
      "/ansible/.+\\.(?:yaml|yml)$/",
    ],
  },
  "ansible-galaxy": {
    managerFilePatterns: [
      "/ansible/.*/requirements(?:\\.ansible)?\\.ya?ml$/",
    ],
  },
}
