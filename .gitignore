terragrunt_rendered.json

# Generated backend.tf files can bake in literal S3/MinIO credentials
# (Terraform backend blocks can't reference variables or data sources).
**/backend.tf

# Talos/OS Images (cached locally, don't commit large binaries)
*.iso
*.img
*.raw
*.qcow2
*.vmdk
*.vdi
terraform/infra/cache/

# Artifact build output directories (large images and binaries)
build/
**/build/talos-iso/
terraform/infra/live/artifacts/build/
terraform/infra/live/artifacts/.terragrunt-cache/
terraform/infra/live/clusters/*/.terragrunt-cache/

