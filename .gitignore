# Generated Talos configs
talos/clusters/**/talconfig.rendered.yaml

# Talos build output (large binary files)
talos/_out/

# Talos generated machine configs (regenerate from Terraform)
talos/clusters/**/controlplane.yaml
talos/clusters/**/worker.yaml
talos/clusters/**/talos*.yaml

# Terraform-generated Talos per-node configs (regenerated by Terragrunt hooks)
terraform/infra/live/**/patch/configs/*.yaml
terraform/infra/live/**/patch/patches/*.yaml

# Shared artifact handoff catalogs (generated by artifacts stack apply hooks)
terraform/infra/live/clusters/_shared/artifacts-registry.json
terraform/infra/live/clusters/_shared/artifacts-schematic.json

# Talos client config (per-user credentials)
talos/clusters/**/talosconfig
talos/clusters/**/kubeconfig
talos/cluster-*/talosconfig
talos/cluster-*/kubeconfig

# Terragrunt-generated Terraform files for service LXC stacks
terraform/infra/live/services/minio-lxc/main.tf
terraform/infra/live/services/minio-lxc/providers.tf
terraform/infra/live/services/tailscale-lxc/main.tf
terraform/infra/live/services/tailscale-lxc/providers.tf
terraform/infra/live/services/zot-lxc/main.tf
terraform/infra/live/services/zot-lxc/providers.tf
terraform/infra/live/services/kanidm/main.tf
terraform/infra/live/services/kanidm/providers.tf
terraform/infra/live/services/smallstep-lxc/main.tf
terraform/infra/live/services/smallstep-lxc/providers.tf
terraform/infra/live/services/tailscale-config/main.tf
terraform/infra/live/services/tailscale-config/providers.tf

# FRR extension symlink (links to separate repository)
# Anchored to repo root - unanchored "FRR/" matched ansible/pve/roles/frr/
# case-insensitively on macOS/APFS and silently excluded that role from
# `git add`.
/FRR/

# Local dev environment (contains OP_SERVICE_ACCOUNT_TOKEN path)
.envrc

# Local Claude/Codex app settings
.claude/settings.json
terraform/infra/live/services/nixtest-lxc/providers.tf
terraform/infra/live/services/nixbuild-vm/providers.tf
