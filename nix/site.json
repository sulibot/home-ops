{
  "domain": "sulibot.com",
  "dns_servers": {
    "ipv4": "10.255.0.53",
    "ipv6": "fd00:0:0:ffff::53"
  },
  "ntp_servers": [
    "fd00:0:0:ffff::53",
    "10.255.0.53"
  ],
  "proxmox": {
    "api_endpoint": "https://10.10.0.1:8006/api2/json",
    "primary_node": "pve01",
    "nodes": {
      "pve01": {
        "mgmt_ip": "10.10.0.1"
      },
      "pve02": {
        "mgmt_ip": "10.10.0.2"
      },
      "pve03": {
        "mgmt_ip": "10.10.0.3"
      }
    }
  },
  "tenants": {
    "100": {
      "purpose": "core service LXCs (kanidm, pki, tailscale)",
      "mode": "sdn"
    },
    "101": {
      "purpose": "cluster-101 (sol)",
      "mode": "sdn"
    },
    "104": {
      "purpose": "cluster-104 (baremetal)",
      "mode": "sdn"
    },
    "200": {
      "purpose": "shared infra (minio, zot, nixos guests)",
      "mode": "vlan"
    }
  },
  "sizes": {
    "micro": {
      "cpu_cores": 1,
      "memory_mb": 512,
      "swap_mb": 256,
      "disk_gb": 8
    },
    "small": {
      "cpu_cores": 2,
      "memory_mb": 2048,
      "swap_mb": 512,
      "disk_gb": 16
    },
    "build": {
      "cpu_cores": 6,
      "memory_mb": 16384,
      "swap_mb": 0,
      "disk_gb": 100
    }
  },
  "services": {
    "kanidm": {
      "role": "kanidm",
      "tenant": 100,
      "size": "small",
      "multi_instance": true
    },
    "minio": {
      "role": "minio",
      "tenant": 200,
      "suffix": 52,
      "node": "pve02",
      "size": "small",
      "hostname": "minio01"
    },
    "zot": {
      "role": "zot",
      "tenant": 200,
      "suffix": 51,
      "node": "pve02",
      "size": "small",
      "hostname": "zot01",
      "override": {
        "disk_gb": 20
      }
    },
    "pki": {
      "role": "pki",
      "tenant": 100,
      "suffix": 64,
      "node": "pve01",
      "size": "small",
      "hostname": "pki01"
    },
    "tail": {
      "role": "tailscale",
      "tenant": 100,
      "size": "micro",
      "instances": {
        "tail01": {
          "suffix": 65,
          "node": "pve01"
        },
        "tail02": {
          "suffix": 66,
          "node": "pve02"
        }
      }
    },
    "nixtest": {
      "role": "nixtest",
      "os": "nixos",
      "tenant": 200,
      "suffix": 202,
      "node": "pve02",
      "size": "micro",
      "hostname": "nixtest01",
      "override": {
        "memory_mb": 1024,
        "swap_mb": 0
      }
    }
  }
}
